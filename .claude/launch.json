{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "claw-web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "web"],
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "claw-api",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "uvicorn", "claw.main:create_app", "--factory", "--port", "8700"],
      "port": 8700,
      "autoPort": true
    }
  ]
}
