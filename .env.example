# Claw Agent v2 configuration (all vars prefixed CLAW_)
#
# For a host-native production install you do NOT need to fill this in by hand:
# `./install.sh` generates a .env (secret key, Postgres URL, password auth) for you.
# This file documents every knob for manual/dev setup and reference.
# Host port 5442 (compose maps 5442->5432 to avoid clashing with other local Postgres)
CLAW_DATABASE_URL=postgresql+asyncpg://claw:claw@localhost:5442/claw
# Run Alembic migrations automatically on startup (recommended for prod).
CLAW_AUTO_MIGRATE=true
CLAW_SECRET_KEY=change-me-32-bytes-random
CLAW_DEV_TOKEN=dev-token
# Auth: "dev" also accepts CLAW_DEV_TOKEN + email (scripts/tests); "password" requires JWT login.
CLAW_AUTH_MODE=dev
CLAW_OPEN_REGISTRATION=true

# OIDC / social login. Public URL of this API + the web app to return to after login.
CLAW_PUBLIC_BASE_URL=http://localhost:8700
CLAW_WEB_BASE_URL=http://localhost:5173
# Google: create an OAuth client, add redirect URI <PUBLIC_BASE_URL>/api/auth/oidc/google/callback
CLAW_OIDC_GOOGLE_CLIENT_ID=
CLAW_OIDC_GOOGLE_CLIENT_SECRET=
# Microsoft (Entra ID): redirect URI <PUBLIC_BASE_URL>/api/auth/oidc/microsoft/callback
CLAW_OIDC_MICROSOFT_CLIENT_ID=
CLAW_OIDC_MICROSOFT_CLIENT_SECRET=
CLAW_OIDC_MICROSOFT_TENANT=common
# Optional Telegram bot token — the Telegram channel starts only when set.
CLAW_TELEGRAM_BOT_TOKEN=

# Default LLM provider (any LiteLLM-supported model)
CLAW_LLM__MODEL=anthropic/claude-sonnet-4-5
CLAW_LLM__API_KEY=
CLAW_LLM__API_BASE=

# Browser automation (needs: uv pip install playwright && playwright install chromium)
CLAW_BROWSER__ENABLED=false
CLAW_BROWSER__HEADLESS=true

# Tool-ephemeral sandbox. IMAGE ships a document/archive stack (reportlab,
# python-docx, python-pptx, openpyxl, pandas, zip/unzip) so the agent can create
# PDF/Word/Excel/PowerPoint. Build it first:
#   docker build -f docker/sandbox.Dockerfile -t claw-sandbox:latest .
CLAW_SANDBOX__ENABLED=true
CLAW_SANDBOX__IMAGE=claw-sandbox:latest
CLAW_SANDBOX__CPU_LIMIT=1.0
CLAW_SANDBOX__MEMORY_LIMIT=1g
# bridge = agent gets internet (can pip install on demand; every run is audit-logged);
# none = fully isolated to what's baked into the image.
CLAW_SANDBOX__NETWORK=bridge
CLAW_SANDBOX__TIMEOUT_SECONDS=120

# Speech-to-text for the composer mic (Groq Whisper, or any OpenAI-compatible
# /audio/transcriptions endpoint). NOTE: these are NOT CLAW_-prefixed. The mic
# button only appears once QROQ_KEY is set.
QROQ_KEY=
QROQ_URL=https://api.groq.com/openai/v1
QROQ_MODEL=whisper-large-v3

# Text-to-speech for the "read aloud" speaker button on assistant messages.
# Fully independent of Control Plane > LLM Providers — any OpenAI-wire-compatible
# /audio/speech endpoint works (real OpenAI, OpenRouter, a self-hosted gateway).
# The button is hidden and /api/tts returns 503 whenever CLAW_TTS__API_KEY is unset.
CLAW_TTS__API_BASE=https://api.openai.com/v1
CLAW_TTS__API_KEY=
CLAW_TTS__MODEL=tts-1
CLAW_TTS__VOICE=alloy
# Example for routing TTS through OpenRouter instead of real OpenAI:
# CLAW_TTS__API_BASE=https://openrouter.ai/api/v1
# CLAW_TTS__MODEL=openai/gpt-4o-mini-tts-2025-12-15

# Persistent data roots (attachments, agent-written files, knowledge OKF bundles).
# Defaults are relative (./workspaces, ./knowledge) for local dev. In Docker
# production these are set to an absolute host path via CLAW_DATA_DIR — see below.
# CLAW_WORKSPACES_ROOT=workspaces
# CLAW_KNOWLEDGE_ROOT=knowledge
# Admin-uploaded branding logos (Control Plane > Preferences). Auto-created.
# CLAW_BRANDING_ROOT=branding

# --- Docker production (docker-compose.prod.yml) only ---
# Absolute host directory holding persistent data. It is bind-mounted at the SAME
# path inside the app container so the sandbox's host-daemon bind-mount resolves
# correctly (Docker-outside-of-Docker). Create it first:
#   mkdir -p /srv/claw/data/workspaces /srv/claw/data/knowledge
# CLAW_DATA_DIR=/srv/claw/data
# POSTGRES_PASSWORD=change-me-strong
